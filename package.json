{
  "name": "lark-agent-bridge",
  "version": "0.1.42",
  "description": "Bridge Feishu/Lark messenger with local CLI coding agents (Claude Code, ...)",
  "type": "module",
  "bin": {
    "lark-agent-bridge": "bin/lark-agent-bridge.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "vendor",
    "bin",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release:check": "node tools/release-check.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "1.10.0",
    "@connectrpc/connect": "^1.6.1",
    "@connectrpc/connect-node": "^1.6.1",
    "@cursor/sdk": "file:vendor/cursor-sdk",
    "@cursor/sdk-linux-x64": "file:vendor/cursor-sdk-linux-x64",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@statsig/js-client": "3.31.0",
    "commander": "^12.1.0",
    "https-proxy-agent": "^9.0.0",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  },
  "keywords": [
    "feishu",
    "lark",
    "claude",
    "claude-code",
    "cursor",
    "agent",
    "cli",
    "channel",
    "bridge"
  ],
  "license": "MIT"
}
